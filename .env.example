# mPABS — Business Coach Example Environment Configuration
# Copy this file to .env and adjust values as needed.
# All variables use the BC_ prefix.

# --- LM Studio Connection ---
BC_LM_STUDIO_BASE_URL=http://localhost:1234/v1
BC_LM_STUDIO_API_KEY=not-needed

# --- Model Assignments (per agent task) ---
# Set these to the model name loaded in LM Studio.
# Use "default" to let LM Studio pick the active model.
BC_MODEL_CANVAS=default
BC_MODEL_VOICES=default
BC_MODEL_PLAN=default
BC_MODEL_RESEARCH=default
BC_MODEL_CHAT=default

# --- Embedding ---
# Model name as loaded in LM Studio (used for /v1/embeddings endpoint)
BC_EMBEDDING_MODEL_NAME=text-embedding-nomic-embed-text-v1.5

# --- Database ---
BC_DATABASE_PATH=data/business_coach.db

# --- DOCX Export ---
# Directory containing .docx template files
BC_DOCX_TEMPLATE_DIR=src/business_coach/export/templates
# Template filename (leave empty for blank document)
BC_DOCX_TEMPLATE_NAME=template.docx

# --- Monitoring ---
# Hours between background prior art search cycles
BC_MONITORING_INTERVAL_HOURS=24

# --- Search ---
# Maximum number of results to fetch per source (ArXiv, PubMed, etc.)
BC_SEARCH_MAX_RESULTS_PER_SOURCE=10
# Seconds to wait between requests to the same source (rate limiting)
BC_SEARCH_REQUEST_DELAY_SECONDS=3.0
# Maximum documents to score for relevance
BC_SEARCH_RELEVANCE_TOP_K=200

# --- AI Generation ---
# Maximum tokens for AI responses (increase if outputs are truncated)
BC_DEFAULT_MAX_TOKENS=8192

# --- Logging ---
BC_LOG_FILE_PATH=logs/business_coach.log
# Options: DEBUG, INFO, WARNING, ERROR
BC_LOG_LEVEL=INFO

# --- Web Server ---
BC_NICEGUI_PORT=8080
# Set to true for auto-reload on file changes during development
BC_NICEGUI_RELOAD=false
